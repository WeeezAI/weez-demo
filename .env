# Paddle Configuration
# IMPORTANT: Use the CLIENT-SIDE TOKEN (plt_...) here, NOT the SECRET API KEY (pdl_...)
VITE_PADDLE_CLIENT_TOKEN=your_paddle_client_token_here
VITE_PADDLE_ENVIRONMENT=production

# LinkedIn Intelligence Engine API URL (legacy /api/v1/email/* + /api/v1/calendar/*).
# NOTE: The Connectors view no longer uses this — Gmail / Outlook / Calendar OAuth
# now goes through the main poster-pipeline backend's /integrations/* API (see
# src/services/integrationsAPI.ts), the same connection Max uses to send email.
# Kept here (pinned to production, not localhost:3000) only for any legacy caller.
# For local dev against a locally-running engine, override to http://localhost:3000.
VITE_API_BASE_URL=https://www.dexraflow.com

# Same LinkedIn Intelligence Engine, used by the research-session wizard
# (internalSessionAPI.ts). Also defaulted to localhost:3000, so pin it to the
# production host to avoid the same "can't connect to localhost:3000" failure.
VITE_ENGAGEMENT_BASE_URL=https://www.dexraflow.com
